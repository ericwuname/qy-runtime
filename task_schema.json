{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StandardizedTask",
  "type": "object",
  "required": [
    "id",
    "schemaVersion",
    "executorVersion",
    "description",
    "parameters",
    "executionStatus",
    "results",
    "logs",
    "resourceConsumption"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier of the task"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Version of the task JSON schema (e.g. '1.1')"
    },
    "executorVersion": {
      "type": "string",
      "description": "Version of the executor engine that ran this task (e.g. '1.0.1')"
    },
    "submitter": {
      "type": "string",
      "description": "The authenticated system or entity that submitted this task"
    },
    "generation": {
      "type": "integer",
      "description": "Task lifecycle incarnation version (increased when reclaimed as a zombie)"
    },
    "retryCount": {
      "type": "integer",
      "description": "Number of recovery cycles this task went through"
    },
    "description": {
      "type": "object",
      "required": ["title", "prompt"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable task title"
        },
        "prompt": {
          "type": "string",
          "description": "The system objective or prompt instructions"
        }
      }
    },
    "parameters": {
      "type": "object",
      "required": ["provider", "model", "temperature"],
      "properties": {
        "provider": {
          "type": "string",
          "description": "AI provider, e.g., gemini, openai, anthropic, local_llm"
        },
        "model": {
          "type": "string",
          "description": "Specific model name"
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0
        },
        "systemInstruction": {
          "type": "string",
          "description": "System preset context"
        },
        "additionalParams": {
          "type": "object",
          "description": "Provider-specific parameters such as top_p, max_tokens, etc."
        }
      }
    },
    "executionStatus": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"]
    },
    "results": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Final text result or executive summary generated by the model"
        },
        "outputFiles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of relative paths to files produced or modified during the run"
        },
        "error": {
          "type": "string",
          "description": "Failure details if status is failed"
        },
        "stdout": {
          "type": "string",
          "description": "Captured standard output of physical CLI/Tool processes run during the execution"
        },
        "stderr": {
          "type": "string",
          "description": "Captured standard error of physical CLI/Tool processes run during the execution"
        },
        "errorClassification": {
          "type": "string",
          "enum": ["OS_ERROR", "TOOL_ERROR", "MODEL_ERROR", "SYSTEM_RECLAIM_BREAKER", "UNKNOWN_ERROR"],
          "description": "Categorized root cause of execution failure"
        }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "type", "message"],
        "properties": {
          "timestamp": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["system", "model_thought", "tool_call", "tool_response", "error"]
          },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      }
    },
    "resourceConsumption": {
      "type": "object",
      "required": ["durationMs", "tokensUsed"],
      "properties": {
        "durationMs": { "type": "number" },
        "tokensUsed": { "type": "number" },
        "cpuLoadAvg": { "type": "number" },
        "memoryUsedBytes": { "type": "number" }
      }
    }
  }
}
